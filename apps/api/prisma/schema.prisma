generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  username     String        @unique
  password     String
  role         Role          @default(ADMIN)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  refreshToken RefreshToken?
}

enum Role {
  OWNER
  ADMIN
  VIEWER
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @unique
  token     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id            String    @id @default(uuid())
  name          String
  brand         String?
  size          String?
  sizeMl        Int?
  concentration String?
  gender        Gender    @default(UNISEX)
  description   String?
  imageUrl      String?
  costPrice     Decimal   @db.Decimal(10, 2)
  salePrice     Decimal   @db.Decimal(10, 2)
  minStock      Int       @default(2)
  notes         String?
  isPublished   Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  restocks      Restock[]
  sales         Sale[]
}

enum Gender {
  HOMBRE
  MUJER
  UNISEX
}

enum SaleStatus {
  ACTIVA
  ANULADA
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Order {
  id             String         @id @default(uuid())
  date           DateTime
  supplierId     String?
  supplier       Supplier?      @relation(fields: [supplierId], references: [id])
  shippingCost   Decimal        @default(0) @db.Decimal(10, 2)
  marketingCost  Decimal        @default(0) @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  restocks       Restock[]
  fundingEntries FundingEntry[]
}

model Restock {
  id           String   @id @default(uuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  quantity     Int
  baseUnitCost Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  sales        Sale[]   @relation("RestockSource")
}

model FundingEntry {
  id       String  @id @default(uuid())
  orderId  String
  order    Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  investor String
  method   String
  amount   Decimal @db.Decimal(10, 2)
}

model Client {
  id        String    @id @default(uuid())
  name      String
  ci        String?
  phone     String?
  address   String?
  notes     String?
  source    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sales     Sale[]
  payments  Payment[]
}

model Sale {
  id              String    @id @default(uuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id])
  productId       String
  product         Product   @relation(fields: [productId], references: [id])
  restockSourceId String?
  restockSource   Restock?  @relation("RestockSource", fields: [restockSourceId], references: [id])
  status          SaleStatus @default(ACTIVA)
  total           Decimal   @db.Decimal(10, 2)
  unitCostAtSale  Decimal?  @db.Decimal(10, 2)
  profitAtSale    Decimal?  @db.Decimal(10, 2)
  marginPctAtSale Decimal?  @db.Decimal(5, 2)
  date            DateTime
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  payments        Payment[]
}

model Payment {
  id            String   @id @default(uuid())
  saleId        String
  sale          Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  amount        Decimal  @db.Decimal(10, 2)
  paymentMethod String
  isInitial     Boolean  @default(false)
  receiptUrl    String?
  date          DateTime
  notes         String?
  createdAt     DateTime @default(now())
}

model CashMovement {
  id            String   @id @default(uuid())
  type          String
  source        String
  method        String
  amount        Decimal  @db.Decimal(10, 2)
  date          DateTime
  notes         String?
  owner         String?
  paymentMethod String?
  createdAt     DateTime @default(now())
}
